{
  "name": "1flowbase-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "content:sync": "node scripts/sync-wiki-home-content.mjs",
    "dev": "pnpm content:sync && astro dev",
    "start": "pnpm content:sync && astro dev",
    "check": "pnpm content:sync && astro check",
    "build": "pnpm content:sync && astro check && astro build",
    "preview": "astro preview",
    "deploy": "pnpm build && wrangler deploy",
    "release": "bash scripts/release-cloudflare.sh",
    "release:check": "bash scripts/release-cloudflare.sh --check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "7.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "7.0.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}

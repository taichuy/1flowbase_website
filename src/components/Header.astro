---
import Logo from './Logo.astro';
import { SITE, type Locale, localePath } from '../config';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const path = Astro.url.pathname;
const switchHref = path.startsWith('/404')
  ? lang === 'zh' ? '/' : '/zh/'
  : lang === 'zh'
    ? path.replace(/^\/zh/, '') || '/'
    : `/zh${path === '/' ? '/' : path}`;

const labels = lang === 'zh'
  ? {
      nav: [
        ['产品能力', localePath(lang, '/features/')],
        ['使用场景', localePath(lang, '/use-cases/')],
        ['博客', SITE.blogDirectory],
        ['文档', SITE.docsDirectory],
      ],
      language: 'EN',
      github: 'GitHub',
      menu: '打开导航',
    }
  : {
      nav: [
        ['Features', localePath(lang, '/features/')],
        ['Use cases', localePath(lang, '/use-cases/')],
        ['Blog', SITE.blogDirectory],
        ['Docs', SITE.docsDirectory],
      ],
      language: '中文',
      github: 'GitHub',
      menu: 'Open navigation',
    };
---

<header class="sticky top-0 z-50 border-b border-line/80 bg-paper/85 backdrop-blur-xl">
  <div class="site-container flex h-[4.5rem] items-center justify-between gap-6">
    <a href={localePath(lang)} aria-label="1flowbase home">
      <Logo />
    </a>

    <nav class="hidden items-center gap-7 text-sm font-semibold text-muted md:flex" aria-label="Main navigation">
      {labels.nav.map(([label, href]) => (
        <a class="transition hover:text-emerald" href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noreferrer' : undefined}>
          {label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-2 md:flex">
      <a class="rounded-full px-3 py-2 text-sm font-bold text-muted transition hover:bg-white hover:text-emerald" href={switchHref}>
        {labels.language}
      </a>
      <a class="inline-flex items-center gap-2 rounded-full bg-night px-4 py-2.5 text-sm font-bold text-white shadow-lg shadow-forest/15 transition hover:-translate-y-0.5 hover:bg-forest" href={SITE.repository} target="_blank" rel="noreferrer">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4 fill-current"><path d="M12 .7A11.5 11.5 0 0 0 8.36 23.1c.58.1.79-.25.79-.56v-2.23c-3.22.7-3.9-1.37-3.9-1.37-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.57-.29-5.27-1.28-5.27-5.68 0-1.26.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.16 1.17a10.96 10.96 0 0 1 5.76 0c2.2-1.48 3.16-1.17 3.16-1.17.63 1.58.23 2.75.11 3.04.74.8 1.19 1.82 1.19 3.08 0 4.41-2.7 5.38-5.28 5.67.42.36.79 1.06.79 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .7Z"/></svg>
        {labels.github}
        <span class="border-l border-white/20 pl-2 text-white/72" data-github-stars aria-label="GitHub stars">★ <span data-github-stars-value>197</span></span>
      </a>
    </div>

    <details class="group relative md:hidden">
      <summary class="grid size-10 cursor-pointer list-none place-items-center rounded-full border border-line bg-white text-ink" aria-label={labels.menu}>
        <svg aria-hidden="true" viewBox="0 0 24 24" class="size-5 fill-none stroke-current stroke-2"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
      </summary>
      <div class="absolute right-0 mt-3 w-64 rounded-2xl border border-line bg-white p-3 shadow-2xl shadow-forest/10">
        <nav class="grid gap-1 text-sm font-semibold text-muted">
          {labels.nav.map(([label, href]) => <a class="rounded-xl px-3 py-2.5 hover:bg-paper hover:text-emerald" href={href}>{label}</a>)}
          <a class="rounded-xl px-3 py-2.5 hover:bg-paper hover:text-emerald" href={switchHref}>{labels.language}</a>
          <a class="mt-1 rounded-xl bg-night px-3 py-2.5 text-center text-white" href={SITE.repository}>GitHub · ★ <span data-github-stars-value>197</span></a>
        </nav>
      </div>
    </details>
  </div>
</header>

<script>
  const starNodes = document.querySelectorAll('[data-github-stars-value]');
  const cacheKey = '1flowbase:github-stars';
  const renderStars = (count: number) => {
    const label = new Intl.NumberFormat(undefined, { notation: count >= 1000 ? 'compact' : 'standard', maximumFractionDigits: 1 }).format(count);
    starNodes.forEach((node) => { node.textContent = label; });
  };

  try {
    const cached = JSON.parse(localStorage.getItem(cacheKey) ?? 'null');
    if (cached?.count && Date.now() - cached.savedAt < 10 * 60 * 1000) renderStars(cached.count);

    fetch('https://api.github.com/repos/taichuy/1flowbase', { headers: { Accept: 'application/vnd.github+json' } })
      .then((response) => response.ok ? response.json() : Promise.reject(new Error('GitHub request failed')))
      .then((repository) => {
        if (typeof repository.stargazers_count !== 'number') return;
        renderStars(repository.stargazers_count);
        localStorage.setItem(cacheKey, JSON.stringify({ count: repository.stargazers_count, savedAt: Date.now() }));
      })
      .catch(() => {});
  } catch {
    // The GitHub link remains usable when storage or the public API is unavailable.
  }
</script>

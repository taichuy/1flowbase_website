---
import { SITE, type Locale } from '../config';
import HeroUseCases from './HeroUseCases.astro';

interface Props {
  lang: Locale;
  title: string;
  subTitle: string;
  primaryCta: string;
  secondaryCta: string;
  useCases: string[];
}

const { lang, title, subTitle, primaryCta, secondaryCta, useCases } = Astro.props;
---

<section class="hero-scene min-h-[calc(100svh-4.5rem)]" data-hero-scene>
  <canvas class="hero-scene__canvas" aria-hidden="true"></canvas>
  <div class="hero-scene__glow hero-scene__glow--mint" aria-hidden="true"></div>
  <div class="hero-scene__glow hero-scene__glow--sky" aria-hidden="true"></div>

  <div class="site-container hero-scene__content">
    <h1 class="hero-scene__title">
      <span class="hero-scene__typing" data-typing-text={title}>{title}</span><span class="hero-scene__cursor" aria-hidden="true">|</span>
    </h1>

    <p class="hero-scene__subtitle">{subTitle}</p>

    <!-- Animated Use Cases Section -->
    <div class="mt-9 w-full">
      <HeroUseCases useCases={useCases} lang={lang} />
    </div>

    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a class="inline-flex min-w-44 items-center justify-center gap-2 rounded-full bg-night px-6 py-3.5 text-sm font-black text-white shadow-[0_18px_45px_rgba(4,61,49,.2)] transition hover:-translate-y-0.5 hover:bg-forest" href={SITE.repository} target="_blank" rel="noreferrer">
        {primaryCta}
        <span class="inline-flex items-center gap-1 border-l border-white/20 pl-2 text-white/75" data-github-stars>
          <span aria-hidden="true">★</span><span data-github-stars-value>197</span>
        </span>
      </a>
      <a class="inline-flex min-w-36 items-center justify-center gap-2 rounded-full border border-line bg-white/76 px-6 py-3.5 text-sm font-black text-ink shadow-sm backdrop-blur-xl transition hover:-translate-y-0.5 hover:border-emerald/30 hover:text-emerald" href={SITE.wiki} target="_blank" rel="noreferrer">
        {secondaryCta}<span aria-hidden="true">→</span>
      </a>
    </div>

  </div>

  <div class="hero-scene__scroll" aria-hidden="true">
    <span>{lang === 'zh' ? '向下探索' : 'Explore'}</span><i></i>
  </div>
</section>

<style>
  .hero-scene {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-bottom: 1px solid #dce9e4;
    background:
      radial-gradient(circle at 15% 8%, rgb(100 227 177 / 18%), transparent 30rem),
      radial-gradient(circle at 82% 88%, rgb(104 200 255 / 14%), transparent 34rem),
      linear-gradient(135deg, #fff 38%, #effbf6 100%);
  }

  .hero-scene::before {
    position: absolute;
    inset: 0;
    content: '';
    background-image: radial-gradient(rgb(7 150 103 / 10%) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: linear-gradient(to bottom, black 15%, rgb(0 0 0 / 62%) 70%, transparent 100%);
  }

  .hero-scene__canvas {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .hero-scene__glow {
    position: absolute;
    z-index: 0;
    border-radius: 999px;
    filter: blur(70px);
    animation: hero-float 22s ease-in-out infinite alternate;
  }

  .hero-scene__glow--mint {
    top: -16rem;
    left: -12rem;
    width: 42rem;
    height: 42rem;
    background: rgb(100 227 177 / 20%);
  }

  .hero-scene__glow--sky {
    right: -18rem;
    bottom: -20rem;
    width: 54rem;
    height: 54rem;
    background: rgb(104 200 255 / 16%);
    animation-delay: -8s;
    animation-duration: 30s;
  }

  .hero-scene__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: clamp(2rem, 5.5vh, 4rem);
    padding-bottom: clamp(2.5rem, 6vh, 4.5rem);
    text-align: center;
    animation: hero-arrive 900ms cubic-bezier(.16, 1, .3, 1) both;
    width: 100%;
  }

  .hero-scene__title {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    max-width: 1050px;
    margin: clamp(1.5rem, 4vh, 2.5rem) 0 0;
    color: #08231c;
    font-size: clamp(3.1rem, 8.2vw, 7.8rem);
    font-weight: 820;
    letter-spacing: -.075em;
    line-height: .9;
  }

  .hero-scene__typing {
    background: linear-gradient(120deg, #073d31 5%, #079667 55%, #65d7aa 100%);
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 8px 22px rgb(7 150 103 / 12%));
    padding-right: 0.08em;
  }

  .hero-scene__cursor {
    display: inline-block;
    color: #079667;
    margin-left: 0.05em;
    animation: blink 1s step-end infinite;
  }

  .hero-scene__subtitle {
    max-width: 850px;
    margin: clamp(1.2rem, 3vh, 2rem) auto 0;
    color: #08231c;
    font-size: clamp(1.4rem, 3.2vw, 2.5rem);
    font-weight: 750;
    letter-spacing: -0.04em;
    line-height: 1.15;
  }

  @keyframes blink {
    from, to { color: transparent }
    50% { color: #079667 }
  }





  .hero-scene__scroll {
    position: absolute;
    right: 1.5rem;
    bottom: 1.3rem;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: .65rem;
    color: #6f857e;
    font-family: var(--font-mono);
    font-size: .62rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
  }

  .hero-scene__scroll i {
    width: 1px;
    height: 2.2rem;
    background: linear-gradient(#079667, transparent);
  }

  @keyframes hero-arrive {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes hero-float {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(35px, -25px, 0) scale(1.08); }
  }

  @media (max-width: 640px) {
    .hero-scene__title { font-size: clamp(2.5rem, 11.5vw, 3.6rem); line-height: .94; }
    .hero-scene__subtitle { font-size: clamp(1.2rem, 5.5vw, 1.6rem); line-height: 1.25; margin-top: 1rem; }
    .hero-scene__scroll { display: none; }
    .hero-scene__content { padding-top: 2rem; padding-bottom: 3.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scene__content, .hero-scene__glow { animation: none; }
    .hero-scene__cursor { display: none; }
  }
</style>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll('[data-hero-scene]').forEach((scene) => {
    if (!(scene instanceof HTMLElement)) return;

    // Typing animation
    const typingSpan = scene.querySelector('[data-typing-text]');
    const cursorSpan = scene.querySelector('.hero-scene__cursor');
    if (typingSpan instanceof HTMLElement) {
      const targetText = typingSpan.getAttribute('data-typing-text') || '';
      if (reduceMotion) {
        typingSpan.textContent = targetText;
        if (cursorSpan instanceof HTMLElement) {
          cursorSpan.style.display = 'none';
        }
      } else {
        typingSpan.textContent = ''; // clear static text
        let charIndex = 0;
        const typeSpeed = 120; // ms per char
        const type = () => {
          if (charIndex < targetText.length) {
            typingSpan.textContent += targetText.charAt(charIndex);
            charIndex++;
            setTimeout(type, typeSpeed + (Math.random() - 0.5) * 45);
          } else {
            if (cursorSpan instanceof HTMLElement) {
              setTimeout(() => {
                cursorSpan.style.transition = 'opacity 0.6s ease';
                cursorSpan.style.opacity = '0';
              }, 3000);
            }
          }
        };
        setTimeout(type, 300);
      }
    }



    if (reduceMotion) return;
    const canvas = scene.querySelector('canvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    const context = canvas.getContext('2d');
    if (!context) return;

    let width = 0;
    let height = 0;
    let frame = 0;
    const pointer = { x: -1000, y: -1000 };
    type Leaf = {
      x: number; y: number; depth: number; speed: number; drift: number;
      angle: number; spin: number; size: number;
    };
    type Ripple = { x: number; y: number; radius: number; alpha: number; depth: number };

    const leaves: Leaf[] = Array.from({ length: 38 }, () => ({
      x: Math.random(), y: Math.random(), depth: .3 + Math.random() * .7,
      speed: .00022 + Math.random() * .00038, drift: Math.random() * Math.PI * 2,
      angle: Math.random() * Math.PI * 2, spin: (Math.random() - .5) * .018,
      size: 4 + Math.random() * 7,
    }));
    const ripples: Ripple[] = [];

    const resize = () => {
      const rect = scene.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = rect.width;
      height = rect.height;
      canvas.width = Math.round(width * dpr);
      canvas.height = Math.round(height * dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const drawLeaf = (leaf: Leaf, x: number, y: number) => {
      const scale = .45 + leaf.depth * .65;
      context.save();
      context.translate(x, y);
      context.rotate(leaf.angle);
      context.scale(scale, scale * Math.sin(leaf.angle * .7));
      context.beginPath();
      context.moveTo(0, -leaf.size);
      context.quadraticCurveTo(-leaf.size * .8, 0, 0, leaf.size);
      context.quadraticCurveTo(leaf.size * .8, 0, 0, -leaf.size);
      context.fillStyle = `rgba(7, 150, 103, ${.09 + leaf.depth * .16})`;
      context.shadowColor = 'rgba(100, 227, 177, .28)';
      context.shadowBlur = 8;
      context.fill();
      context.restore();
    };

    const animate = (time: number) => {
      context.clearRect(0, 0, width, height);
      const waterline = height * .82;

      for (const leaf of leaves) {
        leaf.y += leaf.speed * leaf.depth;
        leaf.angle += leaf.spin;
        const x = leaf.x * width + Math.sin(time * .00045 + leaf.drift) * 26 * leaf.depth;
        const y = leaf.y * height;
        const dx = x - pointer.x;
        const dy = y - pointer.y;
        if (dx * dx + dy * dy < 15000) leaf.x += Math.sign(dx || 1) * .00045;

        if (y >= waterline) {
          ripples.push({ x, y: waterline, radius: 2, alpha: .2, depth: leaf.depth });
          leaf.y = -.06 - Math.random() * .15;
          leaf.x = Math.random();
        }
        drawLeaf(leaf, x, y);
      }

      for (let index = ripples.length - 1; index >= 0; index -= 1) {
        const ripple = ripples[index];
        ripple.radius += 1.15;
        ripple.alpha *= .955;
        context.beginPath();
        context.ellipse(ripple.x, ripple.y, ripple.radius, ripple.radius * .18, 0, 0, Math.PI * 2);
        context.strokeStyle = `rgba(7, 150, 103, ${ripple.alpha})`;
        context.lineWidth = .8;
        context.stroke();
        if (ripple.alpha < .008) ripples.splice(index, 1);
      }

      frame = requestAnimationFrame(animate);
    };

    scene.addEventListener('pointermove', (event) => {
      const rect = scene.getBoundingClientRect();
      pointer.x = event.clientX - rect.left;
      pointer.y = event.clientY - rect.top;
    });
    scene.addEventListener('pointerleave', () => { pointer.x = -1000; pointer.y = -1000; });
    const observer = new ResizeObserver(resize);
    observer.observe(scene);
    resize();
    frame = requestAnimationFrame(animate);
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(frame);
      observer.disconnect();
    }, { once: true });
  });
</script>

---
import { Image } from 'astro:assets';
import executionLogs from '../assets/product/execution-logs.jpeg';
import workflowEditor from '../assets/product/workflow-editor.png';
import { SITE, type Locale, localePath } from '../config';
import { homeCopy } from '../data/copy';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const copy = homeCopy[lang];
const installCommand = 'curl -fsSL https://raw.githubusercontent.com/taichuy/1flowbase/main/scripts/shell/docker-deploy.sh | sh';
---

<section class="dark-panel min-h-[calc(100vh-4.5rem)]">
  <div class="site-container relative z-10 grid items-center gap-14 py-16 lg:grid-cols-[0.92fr_1.08fr] lg:py-24">
    <div>
      <div class="inline-flex items-center gap-2 rounded-full border border-emerald/20 bg-white/72 px-3 py-1.5 text-xs font-bold tracking-wide text-emerald shadow-sm shadow-emerald/5">
        <span class="size-1.5 rounded-full bg-emerald shadow-[0_0_12px_rgba(7,150,103,.4)]"></span>
        {copy.badge}
      </div>
      <h1 class:list={['mt-7 max-w-4xl font-[760] tracking-[-0.07em] text-white', lang === 'zh' ? 'text-[clamp(3rem,5.3vw,5rem)] leading-[1.02]' : 'text-[clamp(3rem,7vw,6.4rem)] leading-[0.94]']}>
        {copy.heroTitle}
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-white/66 sm:text-xl">{copy.heroDescription}</p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a class="inline-flex items-center justify-center gap-2 rounded-full bg-night px-6 py-3.5 text-sm font-black text-[#fff] shadow-[0_16px_45px_rgba(4,61,49,0.18)] transition hover:-translate-y-0.5 hover:bg-forest" href={SITE.repository} target="_blank" rel="noreferrer">
          {copy.primaryCta}
          <span aria-hidden="true">↗</span>
        </a>
        <a class="inline-flex items-center justify-center gap-2 rounded-full border border-line bg-white/80 px-6 py-3.5 text-sm font-black text-ink shadow-sm transition hover:-translate-y-0.5 hover:border-emerald/30 hover:text-emerald" href={SITE.wiki} target="_blank" rel="noreferrer">
          {copy.secondaryCta}
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="mt-10 border-t border-line pt-6">
        <p class="text-xs font-bold uppercase tracking-[0.15em] text-white/36">{copy.worksWith}</p>
        <div class="mt-4 flex flex-wrap gap-x-6 gap-y-3 text-sm font-bold text-white/58">
          <span>Claude Code</span><span>Codex</span><span>OpenCode</span><span>Cline</span><span>Continue</span>
        </div>
      </div>
    </div>

    <div class="relative lg:pl-4">
      <div class="absolute -left-7 top-10 hidden h-24 w-px bg-gradient-to-b from-transparent via-emerald/30 to-transparent lg:block"></div>
      <div class="overflow-hidden rounded-[1.6rem] border border-line bg-white/92 shadow-[0_35px_110px_rgba(4,61,49,0.14)] backdrop-blur-xl">
        <div class="flex items-center justify-between border-b border-line px-5 py-3.5 text-xs">
          <div class="flex items-center gap-2 text-white/58"><span class="size-2 rounded-full bg-[#ff766f]"></span><span class="size-2 rounded-full bg-[#ffd36e]"></span><span class="size-2 rounded-full bg-mint"></span><span class="ml-2 font-mono">{copy.visualLabel}</span></div>
          <span class="rounded-full bg-mint/20 px-2.5 py-1 font-bold text-forest">● {copy.visualStatus}</span>
        </div>
        <div class="relative p-4 sm:p-6">
          <div class="grid gap-3 sm:grid-cols-[0.8fr_1fr]">
            <div class="rounded-xl border border-line bg-paper/80 p-4">
              <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-[#1479a8]">Agent request</p>
              <p class="mt-3 text-sm font-bold text-white">Review this implementation and verify the UI screenshot.</p>
            </div>
            <div class="rounded-xl border border-emerald/18 bg-mint/10 p-4">
              <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-emerald">Virtual model endpoint</p>
              <p class="mt-3 font-mono text-sm text-white/75">POST /v1/responses</p>
            </div>
          </div>
          <div class="my-3 flex justify-center text-emerald/50">↓</div>
          <div class="grid gap-3 sm:grid-cols-3">
            {['vision-tool', 'review-panel', 'synthesis'].map((node, index) => (
              <div class="rounded-xl border border-line bg-paper/72 p-4">
                <div class="flex items-center justify-between"><span class="grid size-7 place-items-center rounded-lg bg-mint/20 font-mono text-xs text-emerald">{index + 1}</span><span class="size-1.5 rounded-full bg-emerald shadow-[0_0_10px_rgba(7,150,103,.35)]"></span></div>
                <p class="mt-6 font-mono text-xs font-bold text-white/76">{node}</p>
              </div>
            ))}
          </div>
          <div class="my-3 flex justify-center text-emerald/50">↓</div>
          <div class="rounded-xl border border-sky/25 bg-sky/8 p-4">
            <div class="flex items-center justify-between gap-4"><div><p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-[#1479a8]">Observable answer</p><p class="mt-2 text-sm font-bold text-ink">Final response + full execution trace</p></div><div class="text-right font-mono text-[0.65rem] leading-5 text-muted"><p>4 calls</p><p>8.2s</p><p>12.4k tokens</p></div></div>
          </div>
        </div>
      </div>
      <div class="absolute -bottom-6 -right-2 hidden rounded-xl border border-line bg-white/95 px-4 py-3 text-xs text-muted shadow-2xl shadow-forest/10 backdrop-blur-xl sm:block">
        <span class="font-mono text-emerald">trace.complete</span> · every branch preserved
      </div>
    </div>
  </div>
</section>

<section class="border-b border-line bg-white">
  <div class="site-container grid grid-cols-2 divide-x divide-line py-5 md:grid-cols-4">
    {copy.protocols.map((protocol) => <div class="px-3 py-2 text-center text-[0.72rem] font-black uppercase tracking-[0.12em] text-muted">{protocol}</div>)}
  </div>
</section>

<section id="use-cases" class="section-shell">
  <div class="site-container">
    <span class="eyebrow">{copy.useCasesEyebrow}</span>
    <h2 class="section-title">{copy.useCasesTitle}</h2>
    <p class="section-copy">{copy.useCasesDescription}</p>
    <div class="mt-12 grid gap-5 lg:grid-cols-3">
      {copy.useCases.map((item) => (
        <article class="glass-card group flex min-h-[25rem] flex-col p-7 transition duration-300 hover:-translate-y-1 hover:border-emerald/25 hover:shadow-[0_30px_80px_rgba(4,61,49,0.11)] sm:p-8">
          <div class="flex items-center justify-between"><span class="font-mono text-xs font-black text-emerald">{item.number}</span><span class="grid size-9 place-items-center rounded-full bg-emerald/8 text-emerald transition group-hover:bg-emerald group-hover:text-white">↗</span></div>
          <h3 class="mt-16 text-2xl font-[750] tracking-[-0.04em] text-ink">{item.title}</h3>
          <p class="mt-4 flex-1 leading-7 text-muted">{item.body}</p>
          <p class="mt-7 border-t border-line pt-5 font-mono text-xs leading-6 text-emerald">{item.flow}</p>
        </article>
      ))}
    </div>
    <div class="mt-8 text-center"><a class="inline-flex items-center gap-2 text-sm font-black text-emerald hover:text-forest" href={localePath(lang, '/use-cases/')}>{lang === 'zh' ? '查看完整使用场景' : 'Explore all use cases'} <span>→</span></a></div>
  </div>
</section>

<section id="architecture" class="section-shell bg-white">
  <div class="site-container">
    <span class="eyebrow">{copy.architectureEyebrow}</span>
    <div class="grid gap-8 lg:grid-cols-[1fr_0.78fr] lg:items-end">
      <h2 class="section-title">{copy.architectureTitle}</h2>
      <p class="section-copy lg:mb-1">{copy.architectureDescription}</p>
    </div>
    <div class="mt-14 grid overflow-hidden rounded-[1.75rem] border border-line bg-paper lg:grid-cols-4">
      {copy.architectureSteps.map(([number, title, body], index) => (
        <article class:list={['relative min-h-[15rem] p-7', index > 0 && 'border-t border-line lg:border-l lg:border-t-0']}>
          <span class="font-mono text-xs font-black text-emerald">{number}</span>
          <h3 class="mt-14 text-xl font-[750] tracking-[-0.035em] text-ink">{title}</h3>
          <p class="mt-3 text-sm leading-6 text-muted">{body}</p>
          {index < copy.architectureSteps.length - 1 && <span class="absolute -right-3 top-10 z-10 hidden size-6 place-items-center rounded-full border border-line bg-white text-xs text-emerald lg:grid">→</span>}
        </article>
      ))}
    </div>
  </div>
</section>

<section id="features" class="section-shell">
  <div class="site-container">
    <span class="eyebrow">{copy.featuresEyebrow}</span>
    <h2 class="section-title">{copy.featuresTitle}</h2>
    <div class="mt-12 overflow-hidden rounded-[1.75rem] border border-line bg-white shadow-[0_25px_80px_rgba(4,61,49,0.08)]">
      <div class="border-b border-line bg-[#edf6f2] px-3 pt-3 sm:px-6 sm:pt-6">
        <div class="flex items-center gap-2 px-2 pb-3"><span class="size-2 rounded-full bg-[#ff8c7e]"></span><span class="size-2 rounded-full bg-[#ffd476]"></span><span class="size-2 rounded-full bg-mint"></span><span class="ml-2 font-mono text-[0.65rem] text-muted">1flowbase / workflow-editor</span></div>
        <Image src={workflowEditor} alt="1flowbase visual workflow editor showing a multi-model fusion workflow" widths={[640, 960, 1440, 2034]} sizes="(max-width: 1180px) 100vw, 1180px" class="block w-full rounded-t-xl border border-b-0 border-line" loading="lazy" />
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3">
        {copy.features.map(([title, body], index) => (
          <article class:list={['p-7 sm:p-8', index > 0 && 'border-t border-line', index === 1 && 'md:border-t-0 md:border-l', index === 2 && 'lg:border-t-0 lg:border-l', index > 2 && 'lg:border-t']}>
            <div class="grid size-9 place-items-center rounded-xl bg-emerald/8 font-mono text-xs font-black text-emerald">0{index + 1}</div>
            <h3 class="mt-7 text-xl font-[750] tracking-[-0.035em] text-ink">{title}</h3>
            <p class="mt-3 text-sm leading-7 text-muted">{body}</p>
          </article>
        ))}
      </div>
    </div>
    <div class="mt-8 text-center"><a class="inline-flex items-center gap-2 text-sm font-black text-emerald hover:text-forest" href={localePath(lang, '/features/')}>{lang === 'zh' ? '了解全部产品能力' : 'See every capability'} <span>→</span></a></div>
  </div>
</section>

<section id="observability" class="section-shell bg-white">
  <div class="site-container grid gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
    <div>
      <span class="eyebrow">{copy.observeEyebrow}</span>
      <h2 class="section-title">{copy.observeTitle}</h2>
      <p class="section-copy">{copy.observeDescription}</p>
      <ul class="mt-8 grid gap-4">
        {copy.observePoints.map((point) => <li class="flex items-center gap-3 text-sm font-bold text-ink"><span class="grid size-6 place-items-center rounded-full bg-mint/25 text-xs text-forest">✓</span>{point}</li>)}
      </ul>
    </div>
    <div class="overflow-hidden rounded-[1.5rem] border border-line bg-paper p-3 shadow-[0_30px_90px_rgba(4,61,49,0.1)] sm:p-5">
      <div class="mb-3 flex items-center justify-between px-2 text-[0.65rem] font-mono text-muted"><span>execution / trace-7b14</span><span class="text-emerald">● complete</span></div>
      <Image src={executionLogs} alt="1flowbase detailed execution logs with model and tool call traces" widths={[540, 800, 1080]} sizes="(max-width: 1024px) 100vw, 640px" class="w-full rounded-xl border border-line" loading="lazy" />
    </div>
  </div>
</section>

<section class="section-shell">
  <div class="site-container overflow-hidden rounded-[2rem] border border-line bg-white px-6 py-10 text-ink shadow-[0_35px_100px_rgba(4,61,49,0.1)] sm:px-10 sm:py-14 lg:px-16">
    <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
      <div>
        <span class="eyebrow !text-emerald">{copy.installEyebrow}</span>
        <h2 class="mt-4 text-3xl font-[750] leading-tight tracking-[-0.05em] sm:text-5xl">{copy.installTitle}</h2>
        <p class="mt-5 leading-7 text-muted">{copy.installDescription}</p>
      </div>
      <div class="overflow-hidden rounded-2xl border border-white/12 bg-black/22 shadow-2xl">
        <div class="flex items-center justify-between border-b border-white/9 px-4 py-3 text-[0.65rem] font-mono text-white/40"><span>{copy.copyLabel}</span><span>bash</span></div>
        <pre class="overflow-x-auto whitespace-pre-wrap break-all p-5 font-mono text-xs leading-7 text-mint sm:text-sm"><code>{installCommand}</code></pre>
      </div>
    </div>
  </div>
</section>

<section id="faq" class="section-shell bg-white">
  <div class="site-container grid gap-12 lg:grid-cols-[0.72fr_1.28fr]">
    <div>
      <span class="eyebrow">{copy.faqEyebrow}</span>
      <h2 class="section-title">{copy.faqTitle}</h2>
    </div>
    <div class="divide-y divide-line border-y border-line">
      {copy.faqs.map(([question, answer]) => (
        <details class="group py-2">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-5 text-lg font-[720] tracking-[-0.02em] text-ink">
            {question}<span class="grid size-8 shrink-0 place-items-center rounded-full bg-paper text-emerald transition group-open:rotate-45">+</span>
          </summary>
          <p class="max-w-2xl pb-6 pr-10 leading-7 text-muted">{answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<section class="section-shell">
  <div class="site-container text-center">
    <span class="mx-auto grid size-12 place-items-center rounded-2xl bg-gradient-to-br from-mint to-emerald font-black text-night shadow-[0_18px_45px_rgba(7,150,103,0.2)]">1f</span>
    <h2 class="mx-auto mt-7 max-w-4xl text-[clamp(2.5rem,6vw,5.5rem)] font-[760] leading-[0.98] tracking-[-0.065em] text-ink">{copy.finalTitle}</h2>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-muted">{copy.finalDescription}</p>
    <div class="mt-9 flex flex-col justify-center gap-3 sm:flex-row">
      <a class="rounded-full bg-night px-6 py-3.5 text-sm font-black text-white transition hover:-translate-y-0.5 hover:bg-forest" href={SITE.repository}>{copy.primaryCta} ↗</a>
      <a class="rounded-full border border-line bg-white px-6 py-3.5 text-sm font-black text-ink transition hover:border-emerald/30 hover:text-emerald" href={SITE.wiki}>{copy.secondaryCta} →</a>
    </div>
  </div>
</section>

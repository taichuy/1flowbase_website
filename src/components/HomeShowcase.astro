---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../config';

interface Props {
  lang: Locale;
  slides: CollectionEntry<'homeShowcases'>['data']['slides'];
}

const { lang, slides } = Astro.props;
const labels = lang === 'zh'
  ? { region: '首页产品图片轮播', previous: '上一张', next: '下一张' }
  : { region: 'Homepage product image carousel', previous: 'Previous slide', next: 'Next slide' };
---

{slides.length > 0 && (
  <section class="home-showcase-section border-b border-line" data-home-showcase aria-label={labels.region}>
    <div class="site-container">
      <div class="home-showcase-shell">
        <div class="home-showcase-stage" aria-live="off">
          {slides.map((slide, index) => (
            <figure
              class="home-showcase-slide"
              data-showcase-slide
              data-active={index === 0 ? 'true' : 'false'}
              aria-hidden={index === 0 ? 'false' : 'true'}
              inert={index !== 0}
            >
              <div class="home-showcase-image-frame">
                <img
                  src={slide.src}
                  alt={slide.alt}
                  sizes="(max-width: 1180px) calc(100vw - 2rem), 1180px"
                  loading="eager"
                  decoding="async"
                  fetchpriority={index === 0 ? 'high' : 'low'}
                />
              </div>
              <figcaption>{slide.title}</figcaption>
            </figure>
          ))}
        </div>

        <div class="home-showcase-controls">
          <button type="button" data-showcase-previous aria-label={labels.previous}>←</button>
          <div class="home-showcase-progress" aria-hidden="true">
            <span data-showcase-progress></span>
          </div>
          <span class="home-showcase-counter" aria-live="polite">
            <span data-showcase-current>01</span>
            <span>/</span>
            <span>{String(slides.length).padStart(2, '0')}</span>
          </span>
          <button type="button" data-showcase-next aria-label={labels.next}>→</button>
        </div>
      </div>
    </div>
  </section>
)}

<script>
  const setupHomeShowcase = (root: Element) => {
    if (!(root instanceof HTMLElement) || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const slides = Array.from(root.querySelectorAll('[data-showcase-slide]'));
    const previousButton = root.querySelector('[data-showcase-previous]');
    const nextButton = root.querySelector('[data-showcase-next]');
    const currentLabel = root.querySelector('[data-showcase-current]');
    const progress = root.querySelector('[data-showcase-progress]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let activeIndex = 0;
    let timer: number | undefined;

    const render = () => {
      slides.forEach((slide, index) => {
        if (!(slide instanceof HTMLElement)) return;
        const active = index === activeIndex;
        slide.dataset.active = active ? 'true' : 'false';
        slide.setAttribute('aria-hidden', active ? 'false' : 'true');
        slide.inert = !active;
      });
      if (currentLabel) currentLabel.textContent = String(activeIndex + 1).padStart(2, '0');
      if (progress instanceof HTMLElement) {
        progress.style.transform = `scaleX(${(activeIndex + 1) / slides.length})`;
      }
    };

    const clearTimer = () => {
      if (timer !== undefined) window.clearTimeout(timer);
      timer = undefined;
    };

    const schedule = () => {
      clearTimer();
      if (reducedMotion || document.hidden || slides.length < 2) return;
      timer = window.setTimeout(() => {
        activeIndex = (activeIndex + 1) % slides.length;
        render();
        schedule();
      }, 1000);
    };

    const select = (nextIndex: number) => {
      activeIndex = (nextIndex + slides.length) % slides.length;
      render();
      schedule();
    };

    previousButton?.addEventListener('click', () => select(activeIndex - 1));
    nextButton?.addEventListener('click', () => select(activeIndex + 1));

    const handleVisibility = () => document.hidden ? clearTimer() : schedule();
    document.addEventListener('visibilitychange', handleVisibility);
    document.addEventListener('astro:before-swap', () => {
      clearTimer();
      document.removeEventListener('visibilitychange', handleVisibility);
    }, { once: true });

    render();
    schedule();
  };

  document.querySelectorAll('[data-home-showcase]').forEach(setupHomeShowcase);
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-home-showcase]').forEach(setupHomeShowcase);
  });
</script>

<style>
  .home-showcase-section {
    padding-block: clamp(3.5rem, 7vw, 6.5rem);
    background:
      radial-gradient(circle at 90% 8%, rgb(104 200 255 / 13%), transparent 30rem),
      radial-gradient(circle at 5% 94%, rgb(100 227 177 / 13%), transparent 28rem),
      #f7fbf9;
  }

  .home-showcase-shell {
    overflow: hidden;
    border: 1px solid #dce9e4;
    border-radius: clamp(1.35rem, 3vw, 2rem);
    background: rgb(255 255 255 / 90%);
    box-shadow: 0 32px 100px rgb(4 61 49 / 10%);
  }

  .home-showcase-stage {
    display: grid;
  }

  .home-showcase-slide {
    grid-area: 1 / 1;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    margin: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.35rem);
    transition: opacity 160ms ease, transform 160ms ease, visibility 160ms;
  }

  .home-showcase-slide[data-active='true'] {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .home-showcase-image-frame {
    display: grid;
    min-height: clamp(22rem, 58vw, 42rem);
    padding: clamp(0.65rem, 2vw, 1.4rem);
    place-items: center;
    background:
      linear-gradient(rgb(4 61 49 / 4%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(4 61 49 / 4%) 1px, transparent 1px),
      #edf6f2;
    background-size: 28px 28px;
  }

  .home-showcase-image-frame img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 39rem;
    border: 1px solid rgb(220 233 228 / 95%);
    border-radius: clamp(0.9rem, 2vw, 1.35rem);
    background: #fff;
    object-fit: contain;
    box-shadow: 0 24px 70px rgb(4 61 49 / 14%);
  }

  .home-showcase-slide figcaption {
    min-height: 6.75rem;
    padding: clamp(1.35rem, 3vw, 2.1rem) clamp(1.25rem, 4vw, 3rem);
    color: #08231c;
    font-size: clamp(1.45rem, 3vw, 2.65rem);
    font-weight: 780;
    letter-spacing: -0.045em;
    line-height: 1.12;
  }

  .home-showcase-controls {
    display: grid;
    grid-template-columns: auto minmax(5rem, 1fr) auto auto;
    align-items: center;
    gap: 0.8rem;
    border-top: 1px solid #dce9e4;
    padding: 0.9rem clamp(1rem, 3vw, 2rem);
  }

  .home-showcase-controls button {
    display: grid;
    width: 2.55rem;
    height: 2.55rem;
    place-items: center;
    border: 1px solid #dce9e4;
    border-radius: 999px;
    background: #fff;
    color: #087b58;
    cursor: pointer;
    font-weight: 900;
  }

  .home-showcase-progress {
    overflow: hidden;
    height: 0.28rem;
    border-radius: 999px;
    background: #dce9e4;
  }

  .home-showcase-progress span {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    background: #079667;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 160ms ease;
  }

  .home-showcase-counter {
    display: flex;
    gap: 0.35rem;
    min-width: 4.4rem;
    justify-content: center;
    color: #6f8780;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 850;
  }

  @media (max-width: 560px) {
    .home-showcase-section {
      padding-block: 3rem;
    }

    .home-showcase-image-frame {
      min-height: 20rem;
      padding: 0.45rem;
    }

    .home-showcase-slide figcaption {
      min-height: 6rem;
      font-size: 1.5rem;
    }

    .home-showcase-controls {
      grid-template-columns: auto minmax(3rem, 1fr) auto auto;
      gap: 0.55rem;
      padding-inline: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-showcase-slide,
    .home-showcase-progress span {
      transition: none;
    }
  }
</style>

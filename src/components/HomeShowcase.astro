---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../config';

interface Props {
  lang: Locale;
  slides: CollectionEntry<'homeShowcases'>['data']['slides'];
}

const { lang, slides } = Astro.props;
const labels = lang === 'zh'
  ? { region: '首页产品图片轮播', previous: '上一张', next: '下一张', progress: '选择轮播图片' }
  : { region: 'Homepage product image carousel', previous: 'Previous slide', next: 'Next slide', progress: 'Choose a slide' };
---

{slides.length > 0 && (
  <section class="home-showcase-section border-b border-line" data-home-showcase aria-label={labels.region}>
    <div class="site-container">
      <div class="home-showcase-shell">
        <div class="home-showcase-stage" aria-live="off">
          {slides.map((slide, index) => (
            <figure
              class="home-showcase-slide"
              data-showcase-slide
              data-active={index === 0 ? 'true' : 'false'}
              aria-hidden={index === 0 ? 'false' : 'true'}
              inert={index !== 0}
            >
              <figcaption data-showcase-title><span>{slide.title}</span></figcaption>
              <div class="home-showcase-image-frame">
                <img
                  src={slide.src}
                  alt={slide.alt}
                  sizes="(max-width: 1180px) calc(100vw - 2rem), 1180px"
                  loading="eager"
                  decoding="async"
                  fetchpriority={index === 0 ? 'high' : 'low'}
                />
              </div>
            </figure>
          ))}
          <button class="home-showcase-arrow home-showcase-arrow-previous" type="button" data-showcase-previous aria-label={labels.previous}>
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6" /></svg>
          </button>
          <button class="home-showcase-arrow home-showcase-arrow-next" type="button" data-showcase-next aria-label={labels.next}>
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" /></svg>
          </button>
          <div class="home-showcase-progress" role="group" aria-label={labels.progress}>
            {slides.map((slide, index) => (
              <button
                type="button"
                data-showcase-target={index}
                data-active={index === 0 ? 'true' : 'false'}
                aria-label={slide.title}
                aria-current={index === 0 ? 'true' : 'false'}
              ><span></span></button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<script>
  const setupHomeShowcase = (root: Element) => {
    if (!(root instanceof HTMLElement) || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const slides = Array.from(root.querySelectorAll('[data-showcase-slide]'));
    const titles = Array.from(root.querySelectorAll('[data-showcase-title]'));
    const progressButtons = Array.from(root.querySelectorAll('[data-showcase-target]'));
    const previousButton = root.querySelector('[data-showcase-previous]');
    const nextButton = root.querySelector('[data-showcase-next]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let activeIndex = 0;
    let timer: number | undefined;

    const fitTitle = (title: Element) => {
      if (!(title instanceof HTMLElement)) return;
      const text = title.querySelector('span');
      if (!(text instanceof HTMLElement)) return;

      text.style.fontSize = '';
      const maximum = Number.parseFloat(window.getComputedStyle(text).fontSize);
      const minimum = 14;
      let low = minimum;
      let high = maximum;

      const fits = () => title.scrollHeight <= title.clientHeight && title.scrollWidth <= title.clientWidth;
      if (fits()) return;

      while (high - low > 0.5) {
        const next = (low + high) / 2;
        text.style.fontSize = `${next}px`;
        if (fits()) low = next;
        else high = next;
      }
      text.style.fontSize = `${low}px`;
    };

    const fitTitles = () => titles.forEach(fitTitle);

    const render = () => {
      slides.forEach((slide, index) => {
        if (!(slide instanceof HTMLElement)) return;
        const active = index === activeIndex;
        slide.dataset.active = active ? 'true' : 'false';
        slide.setAttribute('aria-hidden', active ? 'false' : 'true');
        slide.inert = !active;
      });
      progressButtons.forEach((button, index) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const active = index === activeIndex;
        button.dataset.active = active ? 'true' : 'false';
        button.setAttribute('aria-current', active ? 'true' : 'false');
      });
    };

    const clearTimer = () => {
      if (timer !== undefined) window.clearTimeout(timer);
      timer = undefined;
    };

    const schedule = () => {
      clearTimer();
      if (reducedMotion || document.hidden || slides.length < 2) return;
      timer = window.setTimeout(() => {
        activeIndex = (activeIndex + 1) % slides.length;
        render();
        schedule();
      }, 2000);
    };

    const select = (nextIndex: number) => {
      activeIndex = (nextIndex + slides.length) % slides.length;
      render();
      schedule();
    };

    previousButton?.addEventListener('click', () => select(activeIndex - 1));
    nextButton?.addEventListener('click', () => select(activeIndex + 1));
    progressButtons.forEach((button, index) => {
      button.addEventListener('click', () => select(index));
    });

    const handleVisibility = () => document.hidden ? clearTimer() : schedule();
    document.addEventListener('visibilitychange', handleVisibility);
    document.addEventListener('astro:before-swap', () => {
      clearTimer();
      resizeObserver.disconnect();
      document.removeEventListener('visibilitychange', handleVisibility);
    }, { once: true });

    const resizeObserver = new ResizeObserver(fitTitles);
    resizeObserver.observe(root);
    document.fonts.ready.then(fitTitles);
    render();
    fitTitles();
    schedule();
  };

  document.querySelectorAll('[data-home-showcase]').forEach(setupHomeShowcase);
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-home-showcase]').forEach(setupHomeShowcase);
  });
</script>

<style>
  .home-showcase-section {
    padding-block: clamp(3.5rem, 7vw, 6.5rem);
    background:
      radial-gradient(circle at 90% 8%, rgb(104 200 255 / 13%), transparent 30rem),
      radial-gradient(circle at 5% 94%, rgb(100 227 177 / 13%), transparent 28rem),
      #f7fbf9;
  }

  .home-showcase-shell {
    overflow: hidden;
    border: 1px solid #dce9e4;
    border-radius: clamp(1.35rem, 3vw, 2rem);
    background: rgb(255 255 255 / 90%);
    box-shadow: 0 32px 100px rgb(4 61 49 / 10%);
  }

  .home-showcase-stage {
    position: relative;
    display: grid;
  }

  .home-showcase-slide {
    grid-area: 1 / 1;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    margin: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.35rem);
    transition: opacity 160ms ease, transform 160ms ease, visibility 160ms;
  }

  .home-showcase-slide[data-active='true'] {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .home-showcase-image-frame {
    display: grid;
    min-height: clamp(22rem, 58vw, 42rem);
    padding: clamp(0.65rem, 2vw, 1.4rem);
    place-items: center;
    background:
      linear-gradient(rgb(4 61 49 / 4%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(4 61 49 / 4%) 1px, transparent 1px),
      #edf6f2;
    background-size: 28px 28px;
  }

  .home-showcase-image-frame img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 39rem;
    border: 1px solid rgb(220 233 228 / 95%);
    border-radius: clamp(0.9rem, 2vw, 1.35rem);
    background: #fff;
    object-fit: contain;
    box-shadow: 0 24px 70px rgb(4 61 49 / 14%);
  }

  .home-showcase-slide figcaption {
    display: flex;
    width: 100%;
    height: 7.5rem;
    box-sizing: border-box;
    align-items: center;
    overflow: hidden;
    padding: clamp(1.35rem, 3vw, 2.1rem) clamp(1.25rem, 4vw, 3rem);
  }

  .home-showcase-slide figcaption span {
    display: block;
    max-width: 100%;
    color: #08231c;
    font-size: clamp(1.45rem, 3vw, 2.65rem);
    font-weight: 780;
    letter-spacing: -0.045em;
    line-height: 1.12;
  }

  .home-showcase-arrow {
    position: absolute;
    top: calc(50% + 3.3rem);
    z-index: 3;
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 0;
    background: transparent;
    color: rgb(4 61 49 / 72%);
    cursor: pointer;
    filter: drop-shadow(0 2px 4px rgb(255 255 255 / 95%));
    transform: translateY(-50%);
    transition: color 160ms ease, transform 160ms ease;
  }

  .home-showcase-arrow:hover {
    color: #079667;
    transform: translateY(-50%) scale(1.05);
  }

  .home-showcase-arrow svg {
    width: 2rem;
    height: 2rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .home-showcase-arrow-previous {
    left: clamp(1rem, 3vw, 2.4rem);
  }

  .home-showcase-arrow-next {
    right: clamp(1rem, 3vw, 2.4rem);
  }

  .home-showcase-progress {
    position: absolute;
    right: 50%;
    bottom: 1.8rem;
    z-index: 3;
    display: flex;
    gap: 0.4rem;
    border: 1px solid rgb(220 233 228 / 80%);
    border-radius: 999px;
    background: rgb(255 255 255 / 88%);
    padding: 0.6rem;
    box-shadow: 0 10px 30px rgb(4 61 49 / 12%);
    backdrop-filter: blur(12px);
    transform: translateX(50%);
  }

  .home-showcase-progress button {
    position: relative;
    overflow: hidden;
    width: 1.5rem;
    height: 0.28rem;
    border: 0;
    border-radius: 999px;
    background: #b8cbc5;
    padding: 0;
    cursor: pointer;
  }

  .home-showcase-progress button span {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: #079667;
    transform: scaleX(0);
    transform-origin: left;
  }

  .home-showcase-progress button[data-active='true'] span {
    animation: showcase-progress 2000ms linear forwards;
  }

  @keyframes showcase-progress {
    to { transform: scaleX(1); }
  }

  @media (max-width: 560px) {
    .home-showcase-section {
      padding-block: 3rem;
    }

    .home-showcase-image-frame {
      min-height: 20rem;
      padding: 0.45rem;
    }

    .home-showcase-slide figcaption {
      height: 6.5rem;
      padding-block: 1.2rem;
    }

    .home-showcase-slide figcaption span {
      font-size: 1.5rem;
    }

    .home-showcase-arrow {
      top: calc(50% + 3rem);
      width: 2.6rem;
      height: 2.6rem;
    }

    .home-showcase-arrow-previous {
      left: 0.8rem;
    }

    .home-showcase-arrow-next {
      right: 0.8rem;
    }

    .home-showcase-progress {
      bottom: 1rem;
      max-width: calc(100% - 7rem);
      gap: 0.28rem;
      padding: 0.48rem;
    }

    .home-showcase-progress button {
      width: 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-showcase-slide,
    .home-showcase-progress button span {
      transition: none;
    }

    .home-showcase-progress button[data-active='true'] span {
      animation: none;
      transform: scaleX(1);
    }
  }
</style>

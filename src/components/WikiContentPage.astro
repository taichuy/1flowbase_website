---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { type Locale, localePath } from '../config';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: CollectionEntry<'wikiPages'>;
  headings: Heading[];
}

const { entry, headings } = Astro.props;
const lang = entry.data.lang as Locale;
const isGuide = entry.data.kind === 'guide';
const guides = isGuide
  ? (await getCollection('wikiPages', ({ data }) => data.kind === 'guide' && data.lang === lang))
      .sort((a, b) => a.data.categoryOrder - b.data.categoryOrder || a.data.order - b.data.order)
  : [];
const categories = Array.from(Map.groupBy(guides, (guide) => guide.data.category));
const alternatePath = entry.data.alternatePath ?? (lang === 'zh' ? '/docs/' : '/zh/docs/');
const copy = lang === 'zh'
  ? { docs: '文档', license: '许可协议', source: '查看原文', sourceLabel: '内容来源', sourceName: '1flowbase 主项目 Wiki', sourceHint: '构建时自动同步最新教程正文', contents: '本文目录', all: '全部文档', collapse: '收起文档目录', expand: '展开文档目录' }
  : { docs: 'Documentation', license: 'License', source: 'View source', sourceLabel: 'Content source', sourceName: '1flowbase project Wiki', sourceHint: 'The latest guide is synced at build time', contents: 'On this page', all: 'All documentation', collapse: 'Collapse documentation', expand: 'Expand documentation' };
const title = isGuide ? entry.data.title : copy.license;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': isGuide ? 'TechArticle' : 'WebPage',
  headline: entry.data.title,
  inLanguage: lang === 'zh' ? 'zh-CN' : 'en',
  isBasedOn: entry.data.sourceUrl,
};
---

<BaseLayout lang={lang} title={title} description={entry.data.title} type={isGuide ? 'article' : 'website'} alternatePath={alternatePath} structuredData={structuredData}>
  <section class="border-b border-line bg-white">
    <div class:list={[isGuide ? 'docs-reader-width' : 'site-container', 'py-10 sm:py-14']}>
      <a class="text-sm font-black text-emerald hover:text-forest" href={isGuide ? localePath(lang, '/docs/') : localePath(lang, '/')}>← {isGuide ? copy.docs : '1flowbase'}</a>
      <div class:list={['mt-8', isGuide && 'grid gap-8 lg:grid-cols-[minmax(0,1fr)_17rem] lg:items-end lg:gap-12']}>
        <div class="min-w-0">
          <p class="font-mono text-xs font-black uppercase tracking-[0.12em] text-emerald">{isGuide ? entry.data.category : copy.license}</p>
          <h1 class:list={['docs-page-title mt-4 text-ink', isGuide ? 'text-[clamp(2.5rem,4vw,4rem)]' : 'max-w-5xl text-[clamp(2.35rem,5.5vw,4.8rem)]']}>{entry.data.title}</h1>
        </div>
        {isGuide ? (
          <aside class="border-l border-line py-1 pl-5">
            <p class="font-mono text-[0.65rem] font-black uppercase tracking-[0.12em] text-emerald">{copy.sourceLabel}</p>
            <p class="mt-3 text-sm font-black text-ink">{copy.sourceName}</p>
            <p class="mt-1.5 text-xs leading-5 text-muted">{copy.sourceHint}</p>
            <a class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-emerald hover:text-forest" href={entry.data.sourceUrl} target="_blank" rel="noreferrer">{copy.source} ↗</a>
          </aside>
        ) : (
          <a class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-muted hover:text-emerald" href={entry.data.sourceUrl} target="_blank" rel="noreferrer">{copy.source} ↗</a>
        )}
      </div>
    </div>
  </section>

  <div class:list={[isGuide ? 'docs-reader-shell' : 'site-container max-w-[940px]', 'py-12 sm:py-16']} data-docs-layout={isGuide ? '' : undefined}>
    {isGuide && (
      <aside class="docs-sidebar hidden lg:block">
        <div class="sticky top-28">
          <div class="mb-4 flex min-h-9 items-center justify-between gap-2">
            <p class="text-sm font-black text-ink" data-sidebar-label>{copy.all}</p>
            <button
              class="grid size-8 shrink-0 place-items-center rounded-lg border border-line bg-white text-muted transition hover:border-emerald/30 hover:text-emerald"
              type="button"
              aria-label={copy.collapse}
              aria-expanded="true"
              title={copy.collapse}
              data-collapse-label={copy.collapse}
              data-expand-label={copy.expand}
              data-docs-sidebar-toggle
            >
              <svg aria-hidden="true" viewBox="0 0 16 16" class="size-4 fill-none stroke-current stroke-[1.5]" data-sidebar-toggle-icon><path d="M10 3 5 8l5 5" /></svg>
            </button>
          </div>
          <nav class="grid gap-2 text-sm" aria-label={copy.all} data-sidebar-content>
            {categories.map(([category, entries]) => {
              const containsCurrent = entries.some((guide) => guide.data.slug === entry.data.slug);
              return (
                <details class="group rounded-xl border border-transparent open:border-line open:bg-white/65" open={containsCurrent}>
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-3 rounded-xl px-3 py-2.5 font-black text-ink hover:bg-white">
                    <span>{category}</span>
                    <svg aria-hidden="true" viewBox="0 0 12 12" class="size-3 shrink-0 fill-none stroke-current stroke-[1.5] transition group-open:rotate-180"><path d="m2.5 4.5 3.5 3 3.5-3" /></svg>
                  </summary>
                  <div class="grid gap-1 border-l border-line pb-2 pl-3 pr-2">
                    {entries.map((guide) => (
                      <a class:list={['rounded-lg px-2 py-1.5 leading-5 hover:bg-paper hover:text-emerald', guide.data.slug === entry.data.slug ? 'bg-paper font-bold text-emerald' : 'text-muted']} href={localePath(lang, `/docs/${guide.data.slug}/`)}>{guide.data.title}</a>
                    ))}
                  </div>
                </details>
              );
            })}
          </nav>
        </div>
      </aside>
    )}

    <article class="prose-site min-w-0">
      <slot />
    </article>

    {isGuide && headings.some((heading) => heading.depth === 2) && (
      <aside class="hidden xl:block">
        <nav class="sticky top-28 border-l border-line pl-4 text-xs" aria-label={copy.contents}>
          <p class="mb-3 font-black uppercase tracking-[0.1em] text-ink">{copy.contents}</p>
          <div class="grid gap-2.5 text-muted">
            {headings.filter((heading) => heading.depth === 2).map((heading) => <a class="leading-5 hover:text-emerald" href={`#${heading.slug}`}>{heading.text}</a>)}
          </div>
        </nav>
      </aside>
    )}
  </div>
</BaseLayout>

{isGuide && (
  <script>
    const storageKey = '1flowbase:docs-sidebar-collapsed';
    document.querySelectorAll<HTMLElement>('[data-docs-layout]').forEach((layout) => {
      const toggle = layout.querySelector<HTMLButtonElement>('[data-docs-sidebar-toggle]');
      if (!toggle) return;

      const render = (collapsed: boolean) => {
        layout.toggleAttribute('data-sidebar-collapsed', collapsed);
        toggle.setAttribute('aria-expanded', String(!collapsed));
        const label = collapsed ? toggle.dataset.expandLabel : toggle.dataset.collapseLabel;
        if (label) {
          toggle.setAttribute('aria-label', label);
          toggle.setAttribute('title', label);
        }
      };

      try {
        render(localStorage.getItem(storageKey) === 'true');
      } catch {
        render(false);
      }

      toggle.addEventListener('click', () => {
        const collapsed = !layout.hasAttribute('data-sidebar-collapsed');
        render(collapsed);
        try {
          localStorage.setItem(storageKey, String(collapsed));
        } catch {
          // The control remains functional when storage is unavailable.
        }
      });
    });
  </script>
)}

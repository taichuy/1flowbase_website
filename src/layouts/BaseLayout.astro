---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE, type Locale } from '../config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  alternatePath?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = SITE.defaultDescription,
  lang = 'en',
  image = '/images/og-default.png',
  type = 'website',
  noindex = false,
  alternatePath,
  structuredData,
} = Astro.props;

const pageTitle = title ? `${SITE.name} · ${title}` : `${SITE.name} · The native foundation for AI apps`;
const site = Astro.site ?? new URL('https://1flowbase-website.taichu2021.workers.dev');
const canonical = new URL(Astro.url.pathname, site);
const englishPath = Astro.url.pathname.replace(/^\/zh(?=\/|$)/, '') || '/';
const chinesePath = `/zh${englishPath === '/' ? '/' : englishPath}`;
const imageUrl = new URL(image, site);
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#041713" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={new URL(englishPath, site)} />
    <link rel="alternate" hreflang="zh-CN" href={new URL(chinesePath, site)} />
    <link rel="alternate" hreflang="x-default" href={new URL(englishPath, site)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="1flowbase Blog" href={new URL('/rss.xml', site)} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
  </head>
  <body>
    <Header lang={lang} alternatePath={alternatePath} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

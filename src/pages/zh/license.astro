---
import { getCollection, render } from 'astro:content';
import WikiContentPage from '../../components/WikiContentPage.astro';

const [entry] = await getCollection('wikiPages', ({ data }) => data.kind === 'license' && data.lang === 'zh');
if (!entry) throw new Error('Chinese license content is missing');
const { Content, headings } = await render(entry);
---

<WikiContentPage entry={entry} headings={headings}>
  <Content />
</WikiContentPage>
